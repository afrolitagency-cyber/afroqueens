# ═══════════════════════════════════════════════════════════════
#  Afroqueens FM — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  Never commit .env.local to git.
# ═══════════════════════════════════════════════════════════════

# ── DATABASE (Supabase Postgres) ──────────────────────────────
# Get from: Supabase > Settings > Database > Connection string
# Neon: use your pooled connection string from the Neon dashboard
# Supabase: use the "Transaction mode" URL (has ?pgbouncer=true)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── DATABASE KEEP-ALIVE (Neon free tier sleeps after ~5 min idle) ─────────────
# Local dev: pings automatically every 4 min while `npm run dev` is running.
# Production (Vercel): vercel.json cron hits /api/cron/keep-alive every 5 min.
# Other hosts: use cron-job.org / UptimeRobot → GET /api/cron/keep-alive every 4–5 min.
# Set CRON_SECRET in production and send: Authorization: Bearer <CRON_SECRET>
# CRON_SECRET="your-random-cron-secret"
# DB_KEEP_ALIVE="true"              # enable in-process pings on long-running servers
# DB_KEEP_ALIVE="false"             # disable dev auto-ping
# DB_KEEP_ALIVE_INTERVAL_MS="240000" # default 4 minutes

# ── SUPABASE (Audio file storage) ────────────────────────────
# Get from: Supabase > Settings > API
# Free plan: 1GB storage, 2GB egress/month — enough for ~200 podcast episodes
# Paid plan (Pro $25/month): 100GB storage, 200GB egress
# Audio bucket: create a public bucket called "afroqueens-audio" in Supabase Storage
# Dashboard: supabase.com/dashboard > Storage > New Bucket > Name: afroqueens-audio > Public: ON
NEXT_PUBLIC_SUPABASE_URL="https://[REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# The bucket name used in lib/supabase.ts — must match what you created above
SUPABASE_AUDIO_BUCKET="afroqueens-audio"

# ── CLOUDINARY (Images) ───────────────────────────────────────
# Used for: artist photos, blog cover images, gallery, episode cover art, inline blog images
# Free plan: 25GB storage, 25GB bandwidth/month, auto image optimisation — plenty to start
# Paid plans start at $89/month if you exceed free limits
# Get credentials from: cloudinary.com > Dashboard (top left)
# All 3 values are required — the app will error without them
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
# Images are uploaded to sub-folders: afroqueens/artists, afroqueens/blog, afroqueens/gallery, afroqueens/episodes
# These folders are created automatically on first upload — no manual setup needed

# ── NEXTAUTH ──────────────────────────────────────────────────
# Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"
# Set to your production domain when deploying (no trailing slash)
# e.g. https://afroqueens.fm
NEXTAUTH_URL="http://localhost:3000"

# ── GOOGLE ANALYTICS 4 ────────────────────────────────────────
# Format: G-XXXXXXXXXX
# Get from: analytics.google.com → Admin → Data Streams → Web Stream → Measurement ID
# Leave blank or omit to disable analytics — the GA script will not load
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ── EMAIL (optional — for future notifications) ───────────────
# Not required now. Add when you want:
#   - Contact form email notifications to admin
#   - Newsletter confirmation emails to subscribers
# Recommended: Resend (resend.com) — simple API, generous free plan (3,000 emails/month)
# RESEND_API_KEY="re_xxxxxxxxxxxx"
# EMAIL_FROM="noreply@afroqueens.fm"

# ═══════════════════════════════════════════════════════════════
#  SETUP CHECKLIST (first time)
# ═══════════════════════════════════════════════════════════════
#
#  1. Copy this file:
#       cp .env.example .env.local
#
#  2. Create accounts (all have free tiers):
#       Supabase  → supabase.com
#       Cloudinary → cloudinary.com
#       Google Analytics → analytics.google.com (optional)
#
#  3. In Supabase Storage, create a public bucket:
#       Name: afroqueens-audio
#       Public: ON (so audio files are streamable)
#
#  4. Fill in all values in .env.local
#
#  5. Push the schema to your database:
#       npm run db:push
#
#  6. Seed the database with sample data:
#       npm run db:seed
#
#  7. Start the dev server:
#       npm run dev
#
#  8. Open http://localhost:3000/admin/login
#       Email:    admin@afroqueens.fm
#       Password: afroqueens2025!
#       ⚠️  Change the password immediately after first login!
#
# ═══════════════════════════════════════════════════════════════
